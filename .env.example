# Copy this file to backend/.env and fill in your values.
# NEVER commit backend/.env to git — it contains secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver for FastAPI; plain psycopg2 URL for Alembic migrations
DATABASE_URL=postgresql+asyncpg://advisor:advisor@localhost:5432/advisor
DATABASE_SYNC_URL=postgresql://advisor:advisor@localhost:5432/advisor

# ── Cache ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose "nvidia" (free tier) or "anthropic"
LLM_PROVIDER=nvidia

# NVIDIA free tier — get your key at https://build.nvidia.com
# Fast dev model: meta/llama-3.1-8b-instruct (~70ms)
# Best quality:   meta/llama-3.3-70b-instruct (~36s cold start on free tier)
NVIDIA_API_KEY=nvapi-...
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

# Anthropic (optional — used when LLM_PROVIDER=anthropic)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings ────────────────────────────────────────────────────────────────
# Local dev: BAAI/bge-small-en-v1.5 (134 MB, 384-dim, runs on CPU, downloads on first run)
# Production upgrade: BAAI/bge-m3 (1024-dim, better multilingual quality)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Candidates each retriever returns before RRF fusion
BM25_TOP_K=20
DENSE_TOP_K=20
# Final chunks passed to the LLM as context
FINAL_TOP_K=5

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
